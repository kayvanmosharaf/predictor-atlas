generator client {
  provider = "prisma-client"
  output   = "../app/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

enum Category {
  POLITICS
  ECONOMICS
  SPORTS
  GEOPOLITICS
  TECHNOLOGY
  OTHER
}

enum Status {
  OPEN
  CLOSED
  RESOLVED
}

enum Visibility {
  PRIVATE
  PUBLIC
}

model Prediction {
  id              String     @id @default(uuid())
  title           String
  description     String
  category        Category   @default(OTHER)
  status          Status     @default(OPEN)
  visibility      Visibility @default(PRIVATE)
  resolutionDate  String?
  resolvedOutcome String?
  imageUrl        String?
  owner           String
  createdAt       DateTime   @default(now())
  updatedAt       DateTime   @updatedAt

  outcomes        Outcome[]
  forecasts       Forecast[]
  gameTheoryModel GameTheoryModel?

  @@index([owner])
  @@index([visibility, status])
}

model Outcome {
  id                   String   @id @default(uuid())
  predictionId         String
  label                String
  description          String?
  nashEquilibriumScore Float?
  probability          Float?
  owner                String
  createdAt            DateTime @default(now())
  updatedAt            DateTime @updatedAt

  prediction Prediction @relation(fields: [predictionId], references: [id], onDelete: Cascade)
  forecasts  Forecast[]

  @@index([predictionId])
}

model Forecast {
  id           String   @id @default(uuid())
  predictionId String
  outcomeId    String
  confidence   Float
  reasoning    String?
  owner        String
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  prediction Prediction @relation(fields: [predictionId], references: [id], onDelete: Cascade)
  outcome    Outcome    @relation(fields: [outcomeId], references: [id], onDelete: Cascade)

  @@unique([owner, outcomeId])
  @@index([predictionId])
  @@index([owner])
}

model GameTheoryModel {
  id                 String   @id @default(uuid())
  predictionId       String   @unique
  players            String
  payoffMatrix       String
  nashEquilibria     String
  dominantStrategies String?
  analysis           String
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt

  prediction Prediction @relation(fields: [predictionId], references: [id], onDelete: Cascade)
}
